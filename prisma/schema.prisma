generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT @map("client")
  TALENT @map("talent")
}

model User {
  id        String   @id @default(cuid())
  authId    String   @unique
  email     String   @unique
  name      String?
  role      UserRole?
  username  String?
  lastname  String?
  firstname String?
  address   String?
  avatarUrl String?
  bio       String?
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
