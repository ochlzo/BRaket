generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId                     String                      @unique @map("user_id")
  authId                     String                      @unique @map("auth_id")
  email                      String                      @unique
  username                   String?                     @unique
  lastName                   String?                     @map("last_name")
  firstName                  String?                     @map("first_name")
  address                    String?
  avatarUrl                  String?
  background_img_url         String?
  facebook_url               String?
  instagram_url              String?
  x_url                      String?
  github_url                 String?
  linkedin_url               String?
  createdAt                  DateTime                    @default(now()) @map("createdAt")
  updatedAt                  DateTime                    @updatedAt @map("updatedAt")
  contactNum                 String?                     @unique @db.VarChar(11)
  initials                   String?
  is_verified                Boolean                     @default(false)
  is_talent                  Boolean                     @default(false)
  ClientProfile              ClientProfile?
  TalentProfile              TalentProfile?
  TalentVerificationRequests TalentVerificationRequest[] @relation("TalentVerificationApplicant")

  @@id([userId, authId])
  @@map("User")
}

model TalentVerificationRequest {
  requestId       String                   @id @default(uuid()) @map("request_id")
  userId          String                   @map("user_id")
  buEmail         String                   @map("bu_email")
  buIdImageBucket String                   @map("bu_id_image_bucket")
  buIdImagePath   String                   @map("bu_id_image_path")
  status          TalentVerificationStatus @default(PENDING)
  rejectionReason String?                  @map("rejection_reason")
  reviewedByEmail String?                  @map("reviewed_by_email")
  reviewedAt      DateTime?                @map("reviewed_at")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  User            User                     @relation("TalentVerificationApplicant", fields: [userId], references: [userId], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId, status])
  @@map("talent_verification_requests")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ClientProfile {
  client_profile_id           String            @unique
  user_id                     String            @unique
  organization_name           String
  business_address            String?
  website                     String?
  about                       String?
  client_avg_rating           Float?
  client_review_count         Int?
  client_reputation_score     Float?
  completed_commissions_count Int?
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime
  ClientPortfolio             ClientPortfolio[]
  User                        User              @relation(fields: [user_id], references: [userId], onDelete: Cascade)

  @@id([client_profile_id, user_id])
}

model ClientPortfolio {
  client_portfolio_id  String                 @id
  client_profile_id    String
  title                String
  description          String
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  ClientProfile        ClientProfile          @relation(fields: [client_profile_id], references: [client_profile_id], onDelete: Cascade)
  ClientPortfolioMedia ClientPortfolioMedia[]
}

model ClientPortfolioMedia {
  cportfolio_media_id String          @id
  client_portfolio_id String
  media_url           String
  createdAt           DateTime        @default(now())
  updatedAt           DateTime
  ClientPortfolio     ClientPortfolio @relation(fields: [client_portfolio_id], references: [client_portfolio_id], onDelete: Cascade)
}

model TalentProfile {
  talent_profile_id           String            @unique
  user_id                     String            @unique
  headline                    String
  college                     String
  course                      String
  year_level                  Int
  website                     String?
  talent_avg_rating           Float?
  talent_review_count         Int               @default(0)
  completed_commissions_count Int               @default(0)
  talent_reputation_score     Float?
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime
  bio                         String
  Services                    Service[]
  TalentPortfolio             TalentPortfolio[]
  User                        User              @relation(fields: [user_id], references: [userId], onDelete: Cascade)
  TalentSkills                TalentSkill[]

  @@id([talent_profile_id, user_id])
}

model TalentPortfolio {
  talent_portfolio_id  String                 @id
  talent_profile_id    String
  title                String
  description          String
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  TalentProfile        TalentProfile          @relation(fields: [talent_profile_id], references: [talent_profile_id], onDelete: Cascade)
  TalentPortfolioMedia TalentPortfolioMedia[]
}

model TalentPortfolioMedia {
  tportfolio_media_id String          @id
  talent_portfolio_id String
  media_url           String
  createdAt           DateTime        @default(now())
  updatedAt           DateTime
  TalentPortfolio     TalentPortfolio @relation(fields: [talent_portfolio_id], references: [talent_portfolio_id], onDelete: Cascade)
}

model Skill {
  skillId      String        @id @default(uuid()) @map("skill_id")
  name         String        @unique
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  TalentSkills TalentSkill[]

  @@map("skills")
}

model TalentSkill {
  talentSkillId    String           @id @default(uuid()) @map("talent_skill_id")
  talentProfileId  String           @map("talent_profile_id")
  skillId          String           @map("skill_id")
  proficiencyLevel ProficiencyLevel @map("proficiency_level")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  Skill            Skill            @relation(fields: [skillId], references: [skillId], onDelete: Cascade)
  TalentProfile    TalentProfile    @relation(fields: [talentProfileId], references: [talent_profile_id], onDelete: Cascade)

  @@unique([talentProfileId, skillId])
  @@map("talent_skills")
}

model Service {
  serviceId         String            @id @default(uuid()) @map("service_id")
  talentProfileId   String            @map("talent_profile_id")
  title             String
  minPrice          Decimal           @map("min_price") @db.Decimal(10, 2)
  maxPrice          Decimal           @map("max_price") @db.Decimal(10, 2)
  priceUnit         PriceUnit         @map("price_unit")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  description       String
  ServiceCategories ServiceCategory[]
  ServiceMedia      ServiceMedia[]
  TalentProfile     TalentProfile     @relation(fields: [talentProfileId], references: [talent_profile_id], onDelete: Cascade)

  @@map("Services")
}

model Category {
  categoryId        String            @id @default(uuid()) @map("category_id")
  name              String
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  ServiceCategories ServiceCategory[]

  @@map("Categories")
}

model ServiceCategory {
  serviceCategoryId String   @id @default(uuid()) @map("service_category_id")
  categoryId        String   @map("category_id")
  serviceId         String   @map("service_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  Category          Category @relation(fields: [categoryId], references: [categoryId], onDelete: Cascade)
  Service           Service  @relation(fields: [serviceId], references: [serviceId], onDelete: Cascade)

  @@map("ServiceCategories")
}

model ServiceMedia {
  serviceDetailId String   @id @default(uuid()) @map("service_detail_id")
  serviceId       String   @map("service_id")
  mediaUrl        String   @map("media_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  Service         Service  @relation(fields: [serviceId], references: [serviceId], onDelete: Cascade)

  @@map("ServiceMedia")
}

enum PriceUnit {
  FIXED
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
  PER_PROJECT
  PER_TASK
  PER_SESSION

  @@map("price_unit")
}

enum ProficiencyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT

  @@map("proficiency_level")
}

enum TalentVerificationStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("talent_verification_status")
}
